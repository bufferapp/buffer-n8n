{
	"name": "@bufferapp/n8n-nodes-buffer",
	"version": "3.6.0",
	"description": "n8n nodes for Buffer - Create and manage ideas and posts in your Buffer account",
	"license": "MIT",
	"homepage": "https://github.com/bufferapp/buffer-n8n",
	"keywords": [
		"n8n-community-node-package"
	],
	"author": {
		"name": "Joe Birch",
		"email": "joe@buffer.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bufferapp/buffer-n8n.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/BufferApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Buffer/Buffer.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "^0.17.0",
		"@types/node": "^25.0.3",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"publishConfig": {
		"access": "public"
	}
}
